// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  // Please set the DATABASE_URL environment variable to your MongoDB connection string.
}

model User {
  id    String  @id @default(auto()) @map("_id") @db.ObjectId
  email String  @unique
  name  String?
}

enum BannerType {
  sale
  daily
  new
}

model Banner {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  bannerType  BannerType
  productId   String?
  categoryId  String?
  title       String
  content     String
  desktopUrl  String?
  mobileUrl   String?
  tabletUrl   String?
  productUrl  String?
  isActive    Boolean  @default(true)
}
